---
import Layout from '../../layouts/Layout.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
---

<Layout title="Case Study | Dari Events" description="Explore our latest event design and execution case study.">
  <main class="text-off-white bg-elegant-black min-h-screen selection:bg-gold selection:text-elegant-black">
    
    <div id="content-shell" class="opacity-0 transition-opacity duration-1000 ease-out">
      
      <header class="relative w-full pt-32 md:pt-48 pb-12 border-b border-off-white/20">
        <div class="w-full px-4 md:px-8">
          <h1 id="project-title" class="text-6xl md:text-[12vw] font-bold font-main uppercase leading-[0.85] tracking-tighter mb-12 break-words"></h1>
          
          <div class="grid grid-cols-2 md:grid-cols-4 gap-0 border-t border-off-white/20">
            <div class="p-4 md:p-8 border-r border-b md:border-b-0 border-off-white/20">
              <p class="text-gold uppercase tracking-[0.2em] text-[10px] mb-2 font-bold">Client</p>
              <p id="project-client" class="text-off-white font-medium text-lg uppercase md:text-xl"></p>
            </div>
            <div class="p-4 md:p-8 border-b md:border-b-0 md:border-r border-off-white/20">
              <p class="text-gold uppercase tracking-[0.2em] text-[10px] mb-2 font-bold">Date</p>
              <p id="project-date" class="text-off-white font-medium text-lg uppercase md:text-xl"></p>
            </div>
            <div id="project-stats-container" class="col-span-2 md:col-span-2 grid grid-cols-2 w-full hidden">
              </div>
          </div>
        </div>
      </header>

      <section class="w-full h-[70vh] md:h-screen relative overflow-hidden border-b border-off-white/20">
        <div id="featured-image-container" class="absolute inset-0 w-full h-full bg-cover bg-center bg-no-repeat bg-fixed transition-transform duration-1000 scale-105"></div>
      </section>

      <article id="project-layout" class="w-full pb-24">
        </article>

      <section id="related-section" class="w-full border-t border-off-white/20 hidden">
        <div class="w-full px-4 md:px-8 py-12 flex flex-col md:flex-row justify-between items-end border-b border-off-white/20 gap-6">
          <div>
            <p class="text-gold uppercase tracking-[0.3em] text-[10px] mb-2 font-bold">Archive</p>
            <h2 class="text-5xl md:text-7xl font-main font-bold uppercase tracking-tighter">Related Work</h2>
          </div>
          <a href="/portfolio" class="text-off-white hover:text-gold transition-colors uppercase tracking-[0.2em] text-xs font-bold flex items-center gap-2">
            View All Index <span class="text-lg leading-none">→</span>
          </a>
        </div>
        <div id="related-grid" class="w-full grid grid-cols-1 md:grid-cols-3 gap-0">
          </div>
      </section>

      <div class="w-full py-32 border-t border-off-white/20 text-center px-4 md:px-8 bg-gold text-white">
        <p class="uppercase tracking-[0.3em] text-[10px] mb-4 font-bold">The Next Chapter</p>
        <h2 class="text-6xl md:text-[8vw] font-main font-bold uppercase leading-none tracking-tighter mb-12">Create<br/>Yours</h2>
        <a href="tel:+251921605961" class="inline-block border-2 border-white text-white px-16 py-6 font-bold uppercase tracking-widest hover:bg-elegant-black hover:text-gold transition-colors duration-300">
          Call Us Now
        </a>
      </div>
    </div>
  </main>
</Layout>

<script>
  const BACKEND_URL = 'https://cms.darievents.com'; // Update for production

  const renderLexical = (content: any) => {
    if (!content || !content.root) return '';
    return content.root.children.map((node: any) => {
      if (node.type === 'paragraph') {
        return `<p class="text-xl md:text-3xl font-medium leading-[1.4] tracking-tight text-off-white mb-10">${node.children.map((c: any) => c.text || '').join('')}</p>`;
      }
      if (node.type === 'list') {
        const items = node.children.map((li: any) => `<li class="mb-4 pl-4 border-l-2 border-gold">${li.children.map((c: any) => c.text || '').join('')}</li>`).join('');
        const tag = node.listType === 'number' ? 'ol' : 'ul';
        return `<${tag} class="text-lg md:text-xl text-off-white/80 mb-12 font-medium">${items}</${tag}>`;
      }
      return '';
    }).join('');
  };

  // Dynamic SEO Injection for Google Bot JS rendering
  const injectSEO = (project: any) => {
    document.title = `${project.title.toUpperCase()} | Dari Events`;
    
    let metaDesc = document.querySelector('meta[name="description"]');
    if (!metaDesc) {
      metaDesc = document.createElement('meta');
      metaDesc.setAttribute('name', 'description');
      document.head.appendChild(metaDesc);
    }
    
    // Attempt to grab the first text content block for the meta description
    const firstContentBlock = project.layout?.find((b: any) => b.blockType === 'content');
    const firstTextNode = firstContentBlock?.body?.root?.children?.find((c: any) => c.type === 'paragraph')?.children?.[0]?.text;
    
    metaDesc.setAttribute('content', firstTextNode ? firstTextNode.substring(0, 160) + '...' : `Explore the definitive case study for ${project.title} by Dari Events.`);
  };

  const initPage = async () => {
    const pathSegments = window.location.pathname.split('/').filter(Boolean);
    const slug = pathSegments[pathSegments.length - 1];

    try {
      // 1. Fetch Project
      const res = await fetch(`${BACKEND_URL}/api/case-studies?where[slug][equals]=${slug}&depth=2`);
      const data = await res.json();
      const project = data.docs[0];

      if (!project) {
        window.location.href = '/404';
        return;
      }

      // Update SEO
      injectSEO(project);

      // Populate Header
      document.getElementById('project-title')!.innerText = project.title;
      document.getElementById('project-client')!.innerText = project.client || 'Internal';
      document.getElementById('project-date')!.innerText = project.date 
        ? new Date(project.date).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) 
        : '2024';
      
      // Populate Parallax Featured Image
      const featuredImgContainer = document.getElementById('featured-image-container') as HTMLDivElement;
      if (project.featuredImage?.url) {
        featuredImgContainer.style.backgroundImage = `url(${BACKEND_URL}${project.featuredImage.url})`;
      }

      // Populate Stats (Strict Grid)
      if (project.stats && project.stats.length > 0) {
        const statsContainer = document.getElementById('project-stats-container')!;
        statsContainer.classList.remove('hidden');
        statsContainer.innerHTML = project.stats.map((stat: any, index: number) => {
          const borderClass = index % 2 === 0 ? 'border-r border-off-white/20' : '';
          return `
          <div class="p-4 md:p-8 ${borderClass} flex flex-col justify-center">
            <p class="text-4xl md:text-6xl font-bold font-main text-gold uppercase leading-none mb-2">${stat.value}</p>
            <p class="text-[10px] uppercase font-bold tracking-[0.2em] text-off-white/60">${stat.label}</p>
          </div>
        `}).join('');
      }

      // Populate Content Blocks
      const layoutContainer = document.getElementById('project-layout')!;
      layoutContainer.innerHTML = project.layout?.map((block: any) => {
        
        // TEXT BLOCK: Restricted width for readability, but harsh styling
        if (block.blockType === 'content') {
          return `<div class="w-full px-4 md:px-8 py-24 border-b border-off-white/20"><div class="max-w-4xl mx-auto prose-custom">${renderLexical(block.body)}</div></div>`;
        }

        // BENTO IMAGE GRID: Edge-to-edge, varying spans
        if (block.blockType === 'imageGrid' && block.images) {
          return `
            <div class="w-full grid grid-cols-1 md:grid-cols-4 grid-flow-row-dense border-b border-off-white/20">
              ${block.images.map((img: any, index: number) => {
                // Bento layout logic: creates an asymmetrical, bold grid
                let spanClasses = 'md:col-span-2 md:row-span-2 min-h-[50vh] md:min-h-[80vh]'; // Default Large
                if (index % 4 === 1) spanClasses = 'md:col-span-2 md:row-span-1 min-h-[40vh]'; // Wide Half
                if (index % 4 === 2) spanClasses = 'md:col-span-1 md:row-span-1 min-h-[40vh]'; // Small Square
                if (index % 4 === 3) spanClasses = 'md:col-span-1 md:row-span-1 min-h-[40vh]'; // Small Square

                return `
                <div class="${spanClasses} relative overflow-hidden border border-off-white/20 group">
                  <img src="${BACKEND_URL}${img.url}" class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000E" />
                </div>
              `}).join('')}
            </div>`;
        }

        // VIDEO BLOCK: Edge-to-edge
        if (block.blockType === 'videoHighlight' && block.videoUrl) {
          const isYouTube = block.videoUrl.includes('youtube.com') || block.videoUrl.includes('youtu.be');
          let videoHtml = '';
          
          if (isYouTube) {
            const videoId = block.videoUrl.split('v=')[1] || block.videoUrl.split('/').pop();
            videoHtml = `<iframe class="absolute inset-0 w-full h-full" src="https://www.youtube.com/embed/${videoId}?rel=0" frameborder="0" allowfullscreen></iframe>`;
          } else {
            videoHtml = `<div class="flex items-center justify-center h-full bg-elegant-black"><a href="${block.videoUrl}" target="_blank" class="px-12 py-6 border-2 border-gold text-gold font-bold uppercase tracking-widest hover:bg-gold hover:text-elegant-black transition-colors duration-300">Play Video Sequence</a></div>`;
          }

          return `
            <div class="w-full border-b border-off-white/20 bg-elegant-black">
              <div class="w-full aspect-video relative group">${videoHtml}</div>
              ${block.caption ? `<div class="p-6 border-t border-off-white/20"><p class="text-sm font-bold text-off-white uppercase tracking-[0.2em]">${block.caption}</p></div>` : ''}
            </div>`;
        }
        return '';
      }).join('');

      // 2. Fetch Related (Bento / Brutalist Style)
      const otherRes = await fetch(`${BACKEND_URL}/api/case-studies?where[slug][not_equals]=${slug}&limit=3&depth=1`);
      const otherData = await otherRes.json();
      if (otherData.docs.length > 0) {
        document.getElementById('related-section')!.classList.remove('hidden');
        document.getElementById('related-grid')!.innerHTML = otherData.docs.map((proj: any, index: number) => {
          // Make the first related project span 2 columns on desktop for bento effect
          const gridSpan = index === 0 ? 'md:col-span-2' : 'md:col-span-1';
          return `
          <a href="/portfolio/${proj.slug}" class="group block border-b md:border-b-0 md:border-r border-off-white/20 last:border-r-0 ${gridSpan} relative overflow-hidden min-h-[50vh]">
            <img src="${BACKEND_URL}${proj.featuredImage?.url}" class="absolute inset-0 w-full h-full object-cover opacity-60 transition-all duration-700 group-hover:scale-105 group-hover:opacity-100" />
            <div class="absolute inset-0 p-8 flex flex-col justify-end bg-gradient-to-t from-elegant-black/90 to-transparent">
              <p class="text-gold text-[10px] uppercase font-bold tracking-[0.3em] mb-2">${proj.client || 'Project'}</p>
              <h3 class="text-4xl md:text-5xl font-main font-bold uppercase tracking-tighter text-off-white">${proj.title}</h3>
            </div>
          </a>
        `}).join('');
      }

      // Show Content immediately (no loading screen)
      document.getElementById('content-shell')!.classList.remove('opacity-0');

    } catch (err) {
      console.error('Failed to load project data:', err);
      // Fallback UI handling if needed
    }
  };

  let portfolioSlugLoaded = false;
  const startPortfolioSlug = () => {
    if (portfolioSlugLoaded) return;
    portfolioSlugLoaded = true;
    initPage();
  };

  document.addEventListener('astro:page-load', startPortfolioSlug);
  document.addEventListener('DOMContentLoaded', startPortfolioSlug);
  window.addEventListener('load', startPortfolioSlug);
  if (document.readyState === 'complete' || document.readyState === 'interactive') startPortfolioSlug();
</script>

<style>
  /* Global overrides for this specific page */
  .prose-custom :global(p) { margin-bottom: 2.5rem; }
  .prose-custom :global(ul), .prose-custom :global(ol) {
    margin-bottom: 3.5rem;
  }
  
  /* Hides scrollbar for cleaner edge-to-edge look if preferred */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #000; 
  }
  ::-webkit-scrollbar-thumb {
    background: #333; 
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #f5bd02; 
  }
</style>