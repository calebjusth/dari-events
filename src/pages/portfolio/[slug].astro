---
import Layout from '../../layouts/Layout.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';

---

<Layout title="Case Study | Dari Events">
  <main class="text-off-white min-h-screen">
    
    <div id="loading-overlay" class="fixed inset-0 bg-elegant-black z-50 flex items-center justify-center transition-opacity duration-500">
      
    </div>

    <div id="content-shell" class="opacity-0 transition-opacity duration-1000">
      <header class="relative pt-32 pb-16 px-6 md:px-12 max-w-7xl mx-auto">
        
        
        <div class="grid gap-8 items-end">
          <div>
            <h1 id="project-title" class="text-4xl md:text-8xl font-bold font-main leading-tight mb-6"></h1>
            <div class="flex flex-wrap gap-8 text-sm uppercase tracking-widest text-off-white/40">
              <div>
                <p class="mb-1 text-[10px]">Client</p>
                <p id="project-client" class="text-off-white font-bold"></p>
              </div>
              <div>
                <p class="mb-1 text-[10px]">Date</p>
                <p id="project-date" class="text-off-white font-bold"></p>
              </div>
            </div>
          </div>
          
          <div id="project-stats" class="grid grid-cols-2 gap-8 border-l border-off-white/10 pl-8 hidden">
            </div>
        </div>
      </header>

      <section class="px-4 md:px-6 mb-24">
        <div class="rounded-[40px] overflow-hidden aspect-video bg-off-white/5">
          <img id="featured-image" src="" alt="" class="w-full h-full object-cover" />
        </div>
      </section>

      <article id="project-layout" class="max-w-5xl mx-auto px-6 pb-24">
        </article>

      <section id="related-section" class="max-w-7xl mx-auto px-6 py-24 border-t border-off-white/10 hidden">
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
          <div>
            <p class="text-gold uppercase tracking-[0.3em] text-[10px] mb-4">Discover More</p>
            <h2 class="text-4xl md:text-5xl font-main text-off-white">Related Work</h2>
          </div>
          <a href="/portfolio" class="text-off-white/60 hover:text-off-white transition-colors uppercase tracking-widest text-xs border-b border-off-white/20 pb-2">
            View All Projects
          </a>
        </div>
        <div id="related-grid" class="grid grid-cols-1 md:grid-cols-3 gap-8">
          </div>
      </section>

      <footer class="py-32 border-t border-off-white/10 text-center px-6">
        <p class="text-gold uppercase tracking-[0.3em] text-[10px] mb-4">The Next Chapter</p>
        <h2 class="text-5xl md:text-7xl font-main mb-12">Ready to create yours?</h2>
        <a href="tel:+251921605961" class="inline-block bg-off-white text-elegant-black px-16 py-6 rounded-full font-bold hover:scale-105 transition-all active:scale-95">
          Call Us
        </a>
      </footer>
    </div>
  </main>
</Layout>

<script>
  const BACKEND_URL = 'https://cms.darievents.com'; // Update for production

  const renderLexical = (content: any) => {
    if (!content || !content.root) return '';
    return content.root.children.map((node: any) => {
      if (node.type === 'paragraph') {
        return `<p class="text-xl md:text-2xl leading-relaxed text-off-white/80 mb-8">${node.children.map((c: any) => c.text || '').join('')}</p>`;
      }
      if (node.type === 'list') {
        const items = node.children.map((li: any) => `<li class="mb-2">${li.children.map((c: any) => c.text || '').join('')}</li>`).join('');
        const tag = node.listType === 'number' ? 'ol' : 'ul';
        return `<${tag} class="list-disc list-inside text-lg text-off-white/70 mb-8">${items}</${tag}>`;
      }
      return '';
    }).join('');
  };

  const initPage = async () => {
    // Get slug from URL since Astro.params isn't available in static client scripts
    const pathSegments = window.location.pathname.split('/');
    const slug = pathSegments[pathSegments.length - 1] || pathSegments[pathSegments.length - 2];

    try {
      // 1. Fetch Project
      const res = await fetch(`${BACKEND_URL}/api/case-studies?where[slug][equals]=${slug}&depth=2`);
      const data = await res.json();
      const project = data.docs[0];

      if (!project) {
        window.location.href = '/404';
        return;
      }

      // Populate Header
      document.getElementById('project-title')!.innerText = project.title;
      document.getElementById('project-client')!.innerText = project.client || 'Private';
      document.getElementById('project-date')!.innerText = project.date 
        ? new Date(project.date).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) 
        : '2024';
      
      const featuredImg = document.getElementById('featured-image') as HTMLImageElement;
      featuredImg.src = `${BACKEND_URL}${project.featuredImage?.url}`;
      featuredImg.alt = project.title;

      // Populate Stats
      if (project.stats && project.stats.length > 0) {
        const statsContainer = document.getElementById('project-stats')!;
        statsContainer.classList.remove('hidden');
        statsContainer.innerHTML = project.stats.map((stat: any) => `
          <div>
            <p class="text-4xl md:text-5xl font-bold text-gold">${stat.value}</p>
            <p class="text-[10px] uppercase tracking-widest text-off-white/40">${stat.label}</p>
          </div>
        `).join('');
      }

      // Populate Content Blocks
      const layoutContainer = document.getElementById('project-layout')!;
      layoutContainer.innerHTML = project.layout?.map((block: any) => {
        if (block.blockType === 'content') {
          return `<div class="mb-24 last:mb-0 max-w-3xl prose-custom">${renderLexical(block.body)}</div>`;
        }

        if (block.blockType === 'imageGrid') {
          return `
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-24 last:mb-0">
              ${block.images?.map((img: any) => `
                <div class="rounded-3xl overflow-hidden bg-off-white/5 aspect-[4/5] md:aspect-square">
                  <img src="${BACKEND_URL}${img.url}" class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000" />
                </div>
              `).join('')}
            </div>`;
        }

        if (block.blockType === 'videoHighlight' && block.videoUrl) {
          const isYouTube = block.videoUrl.includes('youtube.com') || block.videoUrl.includes('youtu.be');
          let videoHtml = '';
          
          if (isYouTube) {
            const videoId = block.videoUrl.split('v=')[1] || block.videoUrl.split('/').pop();
            videoHtml = `<iframe class="absolute inset-0 w-full h-full" src="https://www.youtube.com/embed/${videoId}?rel=0" frameborder="0" allowfullscreen></iframe>`;
          } else {
            videoHtml = `<div class="flex items-center justify-center h-full"><a href="${block.videoUrl}" target="_blank" class="px-8 py-4 border border-off-white/20 rounded-full hover:bg-off-white hover:text-elegant-black transition-all">Watch Video Highlight →</a></div>`;
          }

          return `
            <div class="mb-24 last:mb-0">
              <div class="rounded-[40px] overflow-hidden aspect-video bg-black/40 relative group">${videoHtml}</div>
              ${block.caption ? `<p class="mt-6 text-sm text-off-white/30 text-center font-light uppercase tracking-widest">${block.caption}</p>` : ''}
            </div>`;
        }
        return '';
      }).join('');

      // 2. Fetch Related
      const otherRes = await fetch(`${BACKEND_URL}/api/case-studies?where[slug][not_equals]=${slug}&limit=3&depth=1`);
      const otherData = await otherRes.json();
      if (otherData.docs.length > 0) {
        document.getElementById('related-section')!.classList.remove('hidden');
        document.getElementById('related-grid')!.innerHTML = otherData.docs.map((proj: any) => `
          <div class="group cursor-pointer" onclick="window.location.href='/portfolio/${proj.slug}'">
            <div class="aspect-[4/5] rounded-3xl overflow-hidden mb-6">
              <img src="${BACKEND_URL}${proj.featuredImage?.url}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            </div>
            <p class="text-gold text-[10px] uppercase tracking-widest mb-2">${proj.client || 'Project'}</p>
            <h3 class="text-2xl font-main">${proj.title}</h3>
          </div>
        `).join('');
      }

      // Show Content
      document.getElementById('loading-overlay')!.classList.add('opacity-0');
      setTimeout(() => document.getElementById('loading-overlay')!.remove(), 500);
      document.getElementById('content-shell')!.classList.remove('opacity-0');

    } catch (err) {
      console.error(err);
      document.getElementById('loading-overlay')!.innerText = "Error loading content.";
    }
  };

  let portfolioSlugLoaded = false;
  const startPortfolioSlug = () => {
    if (portfolioSlugLoaded) return;
    portfolioSlugLoaded = true;
    initPage();
  };

  document.addEventListener('astro:page-load', startPortfolioSlug);
  document.addEventListener('DOMContentLoaded', startPortfolioSlug);
  window.addEventListener('load', startPortfolioSlug);
  if (document.readyState === 'complete' || document.readyState === 'interactive') startPortfolioSlug();
</script>

<style>
  /* Preserving your exact styles */
  .prose-custom :global(p) { margin-bottom: 2rem; }
  .prose-custom :global(ul) {
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    padding-left: 2rem;
    margin-bottom: 3rem;
  }
</style>