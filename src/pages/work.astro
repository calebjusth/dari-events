---
// portfolio/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Our Work | Dari Events">
  <main class="min-h-screen bg-primary-green">
    <section class="work-gallery pt-48 pb-20 px-4 md:px-8 lg:px-16">
      <div class="max-w-7xl mx-auto">
        
        <div class="mb-20">
          <p class="font-main uppercase tracking-[0.4em] text-[10px] mb-4 text-[#f5bd02]">Portfolio</p>
          <h1 class="text-6xl md:text-8xl font-main italic text-[#f8f8f8] leading-tight">
            Our Work
          </h1>
          <p class="mt-8 text-xl text-[#f8f8f8]/60 max-w-2xl font-light leading-relaxed">
            A curated selection of cinematic experiences and strategic event productions crafted for global impact.
          </p>
        </div>

        <div id="portfolio-grid" class="gallery-grid border-t border-[#f8f8f8]/10 gap-0">
          {[...Array(6)].map((_, i) => (
            <div class="gallery-item animate-pulse border-b border-[#f8f8f8]/10 md:border-r min-h-[340px] flex flex-col">
              <div class="image-container bg-white/5 flex-1 w-full"></div>
              <div class="p-6">
                <div class="h-6 w-1/2 bg-white/10 rounded mb-2"></div>
                <div class="h-4 w-1/3 bg-white/10 rounded"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const BACKEND_URL = "https://cms.darievents.com"; 

  const fetchPortfolio = async () => {
    const grid = document.getElementById('portfolio-grid');
    if (!grid) return;

    try {
      const response = await fetch(`${BACKEND_URL}/api/featured-works?limit=100&depth=2`);
      const data = await response.json();
      const works = data.docs;

      if (works.length > 0) {
        grid.innerHTML = works.map((work: any) => {
          const slug = work.relatedCaseStudy?.slug;
          const hasCaseStudy = !!slug;
          const imageUrl = work.mainMedia?.url 
            ? `${BACKEND_URL}${work.mainMedia.url}` 
            : '/placeholder-event.jpg';

          // Generating the same HTML structure but as a string for injection
          return `
            <${hasCaseStudy ? 'a href="/portfolio/' + slug + '"' : 'div'} class="gallery-item group border-b border-[#f8f8f8]/10 md:border-r">
              <div class="image-container bg-[#f8f8f8]/5">
                <img 
                  src="${imageUrl}" 
                  alt="${work.eventName}" 
                  class="gallery-image" 
                  loading="lazy"
                />
                
                <div class="overlay">
                  <div class="overlay-content p-8 w-full text-left flex flex-col justify-end h-full">
                    <p class="text-[#f5bd02] text-[10px] uppercase tracking-[0.3em] mb-2 opacity-0 group-hover:opacity-100 transition-all duration-700">
                      ${work.client || 'Featured Event'}
                    </p>
                    
                    <h3 class="text-3xl md:text-4xl font-main italic text-white mb-4 leading-tight">
                      ${work.eventName}
                    </h3>
                    
                    ${hasCaseStudy ? `
                      <div class="case-study-link opacity-0 group-hover:opacity-100 transition-all duration-700 delay-100">
                        <span class="text-white text-xs uppercase tracking-widest border-b border-white/40 pb-1 inline-flex items-center gap-2">
                          Explore Case Study <span>→</span>
                        </span>
                      </div>
                    ` : ''}
                  </div>
                </div>
              </div>
            </${hasCaseStudy ? 'a' : 'div'}>
          `;
        }).join('');
      }
    } catch (error) {
      console.error("Error fetching portfolio data:", error);
      grid.innerHTML = `<p class="text-white/40 p-10">Unable to load portfolio at this time.</p>`;
    }
  };

  // Run on initial load and during client-side navigation
  document.addEventListener('astro:page-load', fetchPortfolio);
</script>

<style>
  /* Keeping your exact requested layout logic */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    width: 100%;
    gap: 0;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    text-decoration: none;
    cursor: default;
    min-height: 340px;
    display: flex;
    flex-direction: column;
  }

  a.gallery-item {
    cursor: pointer;
  }

  @media (min-width: 1025px) {
    .gallery-item:nth-child(3n) {
      border-right: none;
    }
  }

  .image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    flex: 1 1 0%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-item:hover .gallery-image {
    transform: scale(1.08);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top, 
      rgba(4, 36, 37, 0.95) 0%, 
      rgba(4, 36, 37, 0.4) 50%, 
      transparent 100%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .gallery-item:hover .overlay {
    opacity: 1;
  }

  .overlay-content {
    transform: translateY(20px);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-item:hover .overlay-content {
    transform: translateY(0);
  }

  @media (max-width: 1024px) and (min-width: 641px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .gallery-item:nth-child(2n) {
      border-right: none;
    }
  }

  @media (max-width: 640px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
    .gallery-item {
      border-right: none !important;
    }
    .image-container {
      aspect-ratio: 4 / 5;
    }
  }
</style>