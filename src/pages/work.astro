---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Archive | Dari Events" description="A curated selection of cinematic experiences and strategic event productions.">
  <main class="min-h-screen bg-elegant-black text-off-white selection:bg-gold selection:text-elegant-black overflow-x-hidden">
    
    <header class="w-full pt-40 md:pt-56 pb-16 px-4 md:px-8 border-b border-off-white/20">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-12 w-full">
        <div class="flex-1">
          <p class="text-gold uppercase tracking-[0.4em] text-[10px] font-bold mb-6">Archive / Index</p>
          <h1 class="text-6xl md:text-[10vw] font-main font-bold uppercase leading-[0.85] tracking-tighter text-off-white break-words">
            Our Work
          </h1>
        </div>
        <div class="max-w-md md:text-right pb-2">
          <p class="text-lg md:text-xl text-off-white/70 font-medium leading-tight border-l-2 md:border-l-0 md:border-r-2 border-gold pl-4 md:pl-0 md:pr-4">
            A curated selection of cinematic experiences and strategic event productions crafted for global impact.
          </p>
        </div>
      </div>
    </header>

    <section class="w-full">
      <div id="portfolio-grid" class="w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 border-l border-off-white/20">
        
        {[...Array(6)].map((_, i) => (
          <div class="border-b border-r border-off-white/20 h-[60vh] md:h-[75vh] flex flex-col bg-elegant-black animate-pulse">
            <div class="flex-grow border-b border-off-white/20 bg-off-white/5 relative">
              <div class="absolute top-4 right-4 bg-elegant-black border border-off-white/20 w-8 h-8"></div>
            </div>
            <div class="h-1/4 min-h-[160px] p-6 flex flex-col justify-between">
              <div class="w-1/3 h-3 bg-off-white/10 mb-4"></div>
              <div class="w-3/4 h-8 bg-off-white/20"></div>
              <div class="w-1/4 h-3 bg-off-white/10 mt-auto"></div>
            </div>
          </div>
        ))}

      </div>
    </section>
    
  </main>
</Layout>

<script>
  const BACKEND_URL = "https://cms.darievents.com"; 

  const fetchPortfolio = async () => {
    const grid = document.getElementById('portfolio-grid');
    if (!grid) return;

    try {
      const response = await fetch(`${BACKEND_URL}/api/featured-works?limit=100&depth=2`);
      const data = await response.json();
      const works = data.docs;

      if (works.length > 0) {
        grid.innerHTML = works.map((work: any, index: number) => {
          const slug = work.relatedCaseStudy?.slug;
          const hasCaseStudy = !!slug;
          const imageUrl = work.mainMedia?.url 
            ? `${BACKEND_URL}${work.mainMedia.url}` 
            : '/placeholder-event.jpg';
          
          // Formats index as 01, 02, etc.
          const numberLabel = index + 1 < 10 ? `0${index + 1}` : `${index + 1}`;

          // Brutalist Grid Cell HTML
          return `
            <${hasCaseStudy ? 'a href="/portfolio/' + slug + '"' : 'div'} class="group block border-b border-r border-off-white/20 h-[60vh] md:h-[75vh] flex flex-col bg-elegant-black cursor-pointer overflow-hidden">
              
              <div class="relative flex-grow border-b border-off-white/20 overflow-hidden bg-elegant-black">
                <img 
                  src="${imageUrl}" 
                  alt="${work.eventName}" 
                  class="absolute inset-0 w-full h-full object-cover grayscale opacity-80 transition-all duration-1000 group-hover:scale-105 group-hover:grayscale-0 group-hover:opacity-100" 
                  loading="lazy"
                />
                <div class="absolute top-4 right-4 bg-elegant-black text-off-white border border-off-white/20 px-3 py-1 text-[10px] uppercase font-bold tracking-[0.2em] z-10 transition-colors duration-500 group-hover:bg-gold group-hover:text-elegant-black group-hover:border-gold">
                  ${numberLabel}
                </div>
              </div>

              <div class="h-[180px] p-6 flex flex-col justify-between bg-elegant-black transition-colors duration-500 group-hover:bg-off-white">
                <div>
                  <p class="text-gold text-[10px] tracking-[0.3em] uppercase mb-3 font-bold transition-colors duration-500 group-hover:text-elegant-black/50 line-clamp-1">
                    ${work.client || 'Featured Work'}
                  </p>
                  <h2 class="text-2xl md:text-3xl font-main font-bold uppercase text-off-white leading-none transition-colors duration-500 group-hover:text-elegant-black line-clamp-2">
                    ${work.eventName}
                  </h2>
                </div>
                
                <div class="flex items-end justify-between mt-4">
                  <p class="text-xs font-bold uppercase tracking-widest text-off-white/40 transition-colors duration-500 group-hover:text-elegant-black">
                    ${hasCaseStudy ? 'Inspect Project' : 'View Details'}
                  </p>
                  <span class="text-gold text-2xl leading-none transition-transform duration-500 group-hover:text-elegant-black group-hover:translate-x-2">
                    →
                  </span>
                </div>
              </div>

            </${hasCaseStudy ? 'a' : 'div'}>
          `;
        }).join('');
      } else {
        grid.innerHTML = `
          <div class="col-span-full border-b border-r border-off-white/20 p-12 text-center">
            <p class="text-2xl font-main font-bold uppercase text-off-white/40">No records found.</p>
          </div>
        `;
      }
    } catch (error) {
      console.error("Error fetching portfolio data:", error);
      grid.innerHTML = `
        <div class="col-span-full border-b border-r border-off-white/20 p-12 text-center bg-red-900/20">
          <p class="text-xl font-bold uppercase tracking-widest text-off-white">System Error: Unable to retrieve archive.</p>
        </div>
      `;
    }
  };

  // Lifecycle execution
  let workPortfolioLoaded = false;
  const startWorkPortfolio = () => {
    if (workPortfolioLoaded) return;
    workPortfolioLoaded = true;
    fetchPortfolio();
  };

  document.addEventListener('astro:page-load', startWorkPortfolio);
  document.addEventListener('DOMContentLoaded', startWorkPortfolio);
  window.addEventListener('load', startWorkPortfolio);
  if (document.readyState === 'complete' || document.readyState === 'interactive') startWorkPortfolio();
</script>

<style>
  /* Hides scrollbar to maintain the strict geometric aesthetic 
    while preserving scrolling functionality. 
  */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #042425; /* Fallback based on your primary green/black */
    border-left: 1px solid rgba(255, 255, 255, 0.2);
  }
  ::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.2); 
    border-radius: 0px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #f5bd02; 
  }
</style>