---
import Layout from '../layouts/Layout.astro';

// SEO Data
const pageTitle = "About Dari Events | Premium Event Agency in Addis Ababa";
const pageDescription = "Dari Events is an experience-first events agency reshaping entertainment, brands, and culture in Ethiopia. Discover our story, impact, and featured projects.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="min-h-screen  overflow-hidden selection:bg-[#f5bd02] selection:text-primary-green">
    
    <!-- Hero Section -->
    <section class="relative min-h-[60vh] md:min-h-[70vh] w-full flex items-start md:items-end justify-center pb-20 md:pb-24 px-6 md:px-12 lg:px-24 pt-32 overflow-hidden bg-cover bg-center" style="background-image: url('/hero-main.jpg');">
      <div class="absolute inset-0 bg-black/65"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/40 to-black/90"></div>

      <div class="relative z-10 max-w-7xl mx-auto w-full">
        <div class="max-w-5xl">
          <span class="inline-block text-[#f5bd02] font-bold uppercase tracking-[0.4em] text-xs mb-6">Who We Are</span>
          <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-9xl font-main font-bold tracking-tighter leading-tight mb-8">
            Experience First.
            <span class="block text-[#f5bd02]/80">Always.</span>
          </h1>
          <p class="text-base sm:text-lg md:text-xl text-off-white/80 font-body max-w-3xl leading-relaxed">
            Reshaping how audiences connect with entertainment, brands, and culture in Ethiopia.
          </p>
        </div>
      </div>
    </section>

    <!-- Story Section -->
    <section class="py-28 px-6 md:px-12 lg:px-24 ">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-20 items-start">
          <div>
            <span class="inline-block font-main text-[11px] uppercase tracking-[0.5em] text-[#f5bd02] mb-6">Our Story</span>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-main font-bold tracking-tighter text-off-white mb-8">
              Born from Passion
            </h2>
            <div class="space-y-6 text-off-white/70 font-body leading-relaxed">
              <p>
                Dari Events was founded when a team of passionate event professionals realized that Addis Ababa was ready for more — more creativity, more organization, more authenticity, and more excitement.
              </p>
              <p>
                With extensive experience delivering some of the city's largest and most acclaimed events, our founders envisioned an agency that brings global-standard execution and fresh creative thinking to every project.
              </p>
              <p class="text-off-white/90 font-medium italic border-l-2 border-[#f5bd02] pl-6">
                We built Dari Events to raise expectations. To redefine what events can feel like. To give audiences and brands the kind of experiences they talk about long after they go home.
              </p>
            </div>
          </div>
          
          <div class="space-y-8">
          <div class="relative rounded-3xl overflow-hidden border border-off-white/10 p-8 bg-cover bg-center" style="background-image: url('/DSC05738.jpg');">
              <div class="absolute inset-0 bg-black/60"></div>
              <div class="absolute top-0 right-0 w-32 h-32 bg-[#f5bd02]/5 rounded-full blur-3xl"></div>
              <div class="relative z-10">
                <div class="text-6xl font-main font-bold text-[#f5bd02] mb-4">"</div>
                <p class="text-off-white/80 font-body text-lg leading-relaxed italic">
                  To reshape how the city experiences events — with creativity, precision, and soul.
                </p>
                <div class="mt-6 flex items-center gap-3">
                  <div class="w-12 h-px bg-[#f5bd02]"></div>
                  <span class="text-xs uppercase tracking-wider text-off-white/40">Our Mission</span>
                </div>
              </div>
            </div>
            
            <div class="grid grid-cols-2 gap-4">
              <div class="p-6 rounded-2xl bg-off-white/5 border border-off-white/10">
                <div class="text-3xl font-main font-bold text-[#f5bd02] mb-2">Rooted</div>
                <p class="text-xs uppercase tracking-wider text-off-white/40">In disruption (politely)</p>
              </div>
              <div class="p-6 rounded-2xl bg-off-white/5 border border-off-white/10">
                <div class="text-3xl font-main font-bold text-[#f5bd02] mb-2">Driven</div>
                <p class="text-xs uppercase tracking-wider text-off-white/40">By passion & purpose</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What We Do & Differentiators -->
    <section class="py-28 px-6 md:px-12 lg:px-24  border-y border-off-white/5">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-20">
          <span class="inline-block font-main text-[11px] uppercase tracking-[0.5em] text-[#f5bd02] mb-4">Our Expertise</span>
          <h2 class="text-5xl md:text-6xl font-main font-bold tracking-tighter text-off-white">What We Do</h2>
          <div class="w-20 h-px bg-[#f5bd02]/50 mx-auto mt-6"></div>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-24">
          {[
            { title: "BTL Activations", desc: "Immersive brand experiences that connect directly with audiences" },
            { title: "Corporate Events & Brand Launches", desc: "Flawless execution for high-stakes brand moments" },
            { title: "Concert & Entertainment", desc: "World-class music experiences and live productions" },
            { title: "Community Engagement Events", desc: "Meaningful gatherings that foster connection" },
            { title: "Event Production & Logistics", desc: "End-to-end operational excellence" },
            { title: "Sponsorship & Talent Management", desc: "Strategic partnerships and artist relations" },
            { title: "Post-Event Analytics & Reporting", desc: "Data-driven insights for measurable impact" }
          ].map((item, i) => (
            <div key={i} class="p-6 rounded-2xl bg-off-white/5 border border-off-white/10 hover:border-[#f5bd02]/30 transition-all duration-300 group">
              <div class="w-10 h-10 rounded-full bg-[#f5bd02]/10 flex items-center justify-center mb-4 group-hover:bg-[#f5bd02]/20 transition-colors">
                <svg class="w-5 h-5 text-[#f5bd02]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <h3 class="font-main font-bold text-off-white mb-2">{item.title}</h3>
              <p class="text-xs text-off-white/40 font-body leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
        
        <div class="grid lg:grid-cols-2 gap-16">
          <div>
            <span class="inline-block font-main text-[11px] uppercase tracking-[0.5em] text-[#f5bd02] mb-6">What Sets Us Apart</span>
            <h3 class="text-3xl md:text-4xl font-main font-bold tracking-tighter text-off-white mb-8">
              Disruptors Elevating<br />Event Culture
            </h3>
          </div>
          <div class="grid gap-4">
            {[
              "Experiences that spark emotion and connect communities",
              "Youthful, energetic creativity grounded in disciplined planning",
              "Fresh ideas that push boundaries",
              "Flawless operations that eliminate stress",
              "Measurable outcomes backed by data and analytics",
              "A bold mission to change how the city experiences events"
            ].map((item, i) => (
              <div key={i} class="flex items-start gap-4 p-4 rounded-xl bg-off-white/5 border border-off-white/10">
                <div class="w-5 h-5 rounded-full bg-[#f5bd02]/20 flex items-center justify-center mt-0.5">
                  <div class="w-2 h-2 rounded-full bg-[#f5bd02]"></div>
                </div>
                <p class="text-off-white/80 font-body text-sm">{item}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>



    <!-- Leadership & Collaborators -->
    

    <!-- Why Dari Events -->
    <section class="py-28 px-6 md:px-12 lg:px-24  border-y border-off-white/5">
      <div class="max-w-4xl mx-auto text-center">
        <span class="inline-block font-main text-[11px] uppercase tracking-[0.5em] text-[#f5bd02] mb-6">Why Choose Us</span>
        <h2 class="text-5xl md:text-6xl font-main font-bold tracking-tighter text-off-white mb-8">
          Bold Creativity.<br />Operational Mastery.
        </h2>
        <div class="w-20 h-px bg-[#f5bd02]/50 mx-auto mb-8"></div>
        <p class="text-xl text-off-white/70 font-body leading-relaxed mb-12">
          We merge bold creativity with operational mastery to deliver standout experiences that live in culture, not just in memory. For brands ready to elevate their presence, inspire audiences, and create moments that matter — Dari Events is the partner that makes it happen.
        </p>
        <a href="/" class="animated-border-button group relative inline-flex items-center justify-center px-10 py-4 overflow-hidden rounded-full bg-transparent transition-all duration-300">
          <span class="relative z-10 font-main font-bold uppercase tracking-[0.2em] text-sm text-off-white group-hover:text-primary-green transition-colors duration-300">Explore Our Events</span>
          <span class="absolute inset-0 rounded-full bg-[#f5bd02] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Animated Border Button */
  .animated-border-button {
    background: transparent;
    position: relative;
    isolation: isolate;
  }
  
  .animated-border-button::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    padding: 2px;
    background: linear-gradient(
      90deg,
      #f5bd02,
      #ff6b6b,
      #4ecdc4,
      #f5bd02
    );
    background-size: 300% 100%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: border-run 3s linear infinite;
  }
  
  @keyframes border-run {
    0% {
      background-position: 0% 0%;
    }
    100% {
      background-position: 300% 0%;
    }
  }
  
  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
  }
  
  ::-webkit-scrollbar-track {
    background: #042425;
  }
  
  ::-webkit-scrollbar-thumb {
    background: #f5bd02;
    border-radius: 3px;
  }
  
  ::-webkit-scrollbar-thumb:hover {
    background: #f5bd02cc;
  }
</style>