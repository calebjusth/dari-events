---
import Layout from '../layouts/Layout.astro';

// SEO Data
const pageTitle = "404 - Event Not Found | Dari Events";
const pageDescription = "Oops! This event seems to have gone off-script. Explore our upcoming experiences instead.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="min-h-screen bg-primary-green overflow-hidden selection:bg-[#f5bd02] selection:text-primary-green">
    
    <!-- Main 404 Content -->
    <section class="relative min-h-screen flex items-center justify-center px-6 md:px-12 lg:px-24 py-32">
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        {/* 404 Number */}
        <div class="relative mb-8">
          <div class="text-[12rem] md:text-[18rem] lg:text-[22rem] font-main font-bold tracking-tighter leading-none select-none">
            <span class="text-off-white/10 relative">404</span>
          </div>
        </div>
        
        {/* Event-Themed Message */}
        <div class="mb-12 space-y-6">
          <div class="inline-block px-6 py-2 rounded-full bg-[#f5bd02]/10 border border-[#f5bd02]/20 mb-4">
            <span class="text-[#f5bd02] text-xs uppercase tracking-[0.3em] font-main font-bold">Event Cancelled</span>
          </div>
          
          <h1 class="text-4xl md:text-6xl font-main font-bold tracking-tighter text-off-white mb-4">
            This Event<br />
            <span class="text-[#f5bd02]">Went Off-Script</span>
          </h1>
          
          <p class="text-off-white/60 text-lg md:text-xl font-body max-w-2xl mx-auto leading-relaxed">
            Looks like this experience either never existed, got lost in the crowd, or is taking an unexpected intermission.
          </p>
        </div>
        
        {/* Action Buttons */}
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/" 
            class="group relative inline-flex items-center justify-center px-8 py-4 overflow-hidden rounded-full bg-[#f5bd02] transition-all duration-300 hover:scale-105"
          >
            <span class="relative z-10 font-main font-bold uppercase tracking-[0.2em] text-sm text-primary-green group-hover:text-primary-green">
              Return to Gallery
            </span>
          </a>
          
          <a 
            href="/events" 
            class="inline-flex items-center justify-center px-8 py-4 rounded-full border border-off-white/30 hover:border-[#f5bd02] hover:bg-off-white/10 transition-all duration-300"
          >
            <span class="font-main uppercase tracking-[0.2em] text-sm text-off-white">
              Explore Events
            </span>
            <svg class="w-4 h-4 ml-2 text-off-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* No animations - clean and simple */
</style>