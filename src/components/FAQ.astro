---
// @ts-nocheck
// src/components/FAQ.astro
// 1. Define a fallback so the site never "crashes" if the CMS is down
const fallbackFaqs = [
  {
    question: 'How far in advance should I book an event?',
    answer: 'We recommend booking at least 3-6 months ahead for larger events.'
  }
];

let faqs = [];
let error = false;

try {
  // 2. Fetch from Payload API (using the slug we created: 'faqs')
  // Note: Use an environment variable for the URL in production
  const response = await fetch(`${import.meta.env.PAYLOAD_URL || 'https://cms.darievents.com'}/api/faqs?limit=100`);
  
  if (!response.ok) throw new Error('Failed to fetch');
  
  const data = await response.json();
  faqs = data.docs;
} catch (e) {
  console.error("Payload Fetch Error:", e);
  faqs = fallbackFaqs; // Switch to fallback data
  error = true;
}
---

<section class="px-4 py-16 md:py-24 bg-[var(--color-primary-green)]">
  <div class="mx-auto max-w-6xl reveal-blur">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-6xl font-bold text-[var(--color-off-white)]">Frequently Asked Questions</h2>
      <p class="mt-4 text-lg md:text-xl text-[var(--color-off-white)]/80 max-w-3xl mx-auto">
        {error ? "Information from our latest planning guide." : "Answers to common questions about how Dari Events brings your vision to life."}
      </p>
    </div>

    <div class="space-y-4">
      {faqs.length > 0 ? (
        faqs.map((item: any, index: number) => (
          <details 
            class="group rounded-2xl border border-[var(--color-off-white)]/30 bg-[var(--color-off-white)]/10 p-6 text-[var(--color-off-white)] transition-all duration-300 hover:border-[var(--color-off-white)] hover:bg-[var(--color-off-white)]/20" 
            open={index === 0}
          >
            <summary class="text-lg md:text-2xl font-bold cursor-pointer outline-none list-none">
              {item.question}
            </summary>
            <p class="mt-4 text-[var(--color-off-white)]/90 text-base md:text-lg leading-relaxed">
              {item.answer}
            </p>
          </details>
        ))
      ) : (
        <p class="text-center text-[var(--color-off-white)]">Check back soon for more updates.</p>
      )}
    </div>
  </div>
</section>

<style>
  /* Keep your existing styles */
  details > summary::-webkit-details-marker {
    display: none;
  }

  .reveal-blur {
    opacity: 0;
    filter: blur(15px);
    transform: translateY(20px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal-blur.active {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }
</style>

<script>
  const initFaqReveal = () => {
    const items = document.querySelectorAll('.reveal-blur');
    if (!items.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.2 });

    items.forEach(el => observer.observe(el));
  };

  document.addEventListener('astro:page-load', initFaqReveal);
  document.addEventListener('DOMContentLoaded', initFaqReveal);
  window.addEventListener('load', initFaqReveal);
  if (document.readyState === 'complete' || document.readyState === 'interactive') initFaqReveal();
</script>