---
// src/components/FAQ.astro
---

<section class="px-4 py-16 md:py-24 bg-[var(--color-primary-green)]">
  <div class="mx-auto max-w-6xl">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-6xl font-bold text-[var(--color-off-white)]">Frequently Asked Questions</h2>
      <p class="mt-4 text-lg md:text-xl text-[var(--color-off-white)]/80 max-w-3xl mx-auto">Answers to common questions about how Dari Events brings your vision to life.</p>
    </div>

    <div class="space-y-4">
      {[
        {
          question: 'How far in advance should I book an event?',
          answer: 'We recommend booking at least 3-6 months ahead for corporate and large-scale events, and 1-3 months for smaller private gatherings to ensure venue and vendor availability.'
        },
        {
          question: 'Can you manage events in multiple cities?',
          answer: 'Absolutely. Dari Events has a regional network and can coordinate multi-city experiences with a local team in place for each location.'
        },
        {
          question: 'What is included in your event planning packages?',
          answer: 'Our packages include venue scouting, creative production, logistics, audio/visual, talent booking, guest management, and on-site production staff.'
        },
        {
          question: 'Do you provide custom branding and theming?',
          answer: 'Yes. We build bespoke themes that align with your brand identity, using design, lighting, and staging to consistently tell your story.'
        },
        {
          question: 'How do we request a quote?',
          answer: 'Use any contact option button in our contact section or email info@darievents.com with your event details, and we’ll send a tailored proposal within 24 hours.'
        }
      ].map((item, index) => (
        <details class="group rounded-2xl border border-[var(--color-off-white)]/30 bg-[var(--color-off-white)]/10 p-6 text-[var(--color-off-white)] transition-all duration-300 hover:border-[var(--color-off-white)] hover:bg-[var(--color-off-white)]/20" open={index===0}>
          <summary class="text-lg md:text-2xl font-bold cursor-pointer outline-none">{item.question}</summary>
          <p class="mt-4 text-[var(--color-off-white)]/90 text-base md:text-lg leading-relaxed">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  details > summary {
    list-style: none;
  }

  details > summary::-webkit-details-marker {
    display: none;
  }

  .reveal-blur {
    opacity: 0;
    filter: blur(15px);
    transform: translateY(20px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal-blur.active {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, { threshold: 0.2 });

  document.querySelectorAll('.reveal-blur').forEach(el => observer.observe(el));
</script>