---
// @ts-nocheck

// This component is now 100% static and compatible with 'dist' deployment.
---

<section id="previous-works" class="relative w-full bg-[#042425] py-10 md:py-20">
  
  <div class="px-8 mb-12 md:hidden">
    <h2 class="text-4xl font-bold tracking-tighter text-[#F8FAF9] font-main">Our Work</h2>
    <p class="text-[#F8FAF9]/60 mt-2 font-body italic">Cinematic moments, curated.</p>
  </div>

  <div id="horizontal-scroll-section" class="relative w-full overflow-x-auto">
    <div id="horizontal-container" class="flex flex-col md:flex-row w-full items-start gap-12 px-6 md:px-24 opacity-0 transition-opacity duration-700">
      </div>
  </div>
</section>

<style>
  #horizontal-container.work-loaded .work-card {
    opacity: 1;
    transform: translateY(0);
  }

  .work-card {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  @media (max-width: 767px) {
    #horizontal-container { display: flex; flex-direction: column; }
  }
  @media (min-width: 768px) {
    #horizontal-container { flex-direction: row; }
  }
</style>

<script>
  const PAYLOAD_URL = "https://cms.darievents.com";

  const fetchAndInit = async () => {
    if (typeof window === 'undefined') return;

    const container = document.querySelector('#horizontal-container');
    if (!container) return;

    try {
      const response = await fetch(`${PAYLOAD_URL}/api/featured-works?where[isActive][equals]=true&sort=rank`);
      const data = await response.json();
      const featuredWorks = /** @type {any[]} */ (data.docs || []);

      if (!featuredWorks.length) {
        container.innerHTML = '<div class="text-white/80 p-12">No featured works available right now.</div>';
        container.classList.remove('opacity-0');
        return;
      }

      const cardsHtml = featuredWorks.map((work) => `
        <div class="work-card relative group flex-shrink-0 w-full md:w-[85vw] h-[60vh] md:h-[75vh] bg-[#042425] rounded-[3rem] overflow-hidden border border-white/5">
          <img 
            src="${PAYLOAD_URL}${work.mainMedia?.url || ''}" 
            alt="${work.eventName || 'Work'}" 
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 opacity-60" 
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#042425] via-transparent to-transparent"></div>
          <div class="absolute inset-0 p-8 md:p-16 flex flex-col justify-end">
            <div class="max-w-3xl">
              ${work.eventLogo ? `
                <img src="${PAYLOAD_URL}${work.eventLogo.url}" alt="${work.eventName} logo" class="h-12 md:h-20 w-auto object-contain mb-8 opacity-90 group-hover:opacity-100 transition-opacity" />
              ` : ''}
              <h3 class="text-4xl md:text-7xl font-main font-bold text-[#F8FAF9] mb-4 tracking-tighter leading-[0.9]">
                ${work.eventName || 'Untitled Work'}
              </h3>
              <p class="text-lg md:text-xl text-[#F8FAF9]/70 font-body max-w-xl mb-10 leading-relaxed italic">
                ${work.shortDescription || 'A featured project from Dari Events.'}
              </p>
              <div class="flex flex-wrap items-center gap-6">
                ${work.relatedCaseStudy ? `
                  <a href="/portfolio/${work.relatedCaseStudy.slug}" class="group/btn inline-flex items-center gap-3 px-8 py-4 bg-[#F8FAF9] text-[#042425] rounded-full font-main font-bold text-xs uppercase tracking-[0.2em] hover:bg-[#f5bd02] transition-all duration-500">
                    Explore Case Study <span class="group-hover/btn:translate-x-2 transition-transform">→</span>
                  </a>
                ` : ''}
                <span class="text-[10px] uppercase tracking-[0.4em] text-[#F8FAF9]/30 font-bold">
                  Client: ${work.client || 'Private'}
                </span>
              </div>
            </div>
          </div>
          <div class="absolute top-12 right-12 font-main text-white/10 text-8xl font-black">
            0${work.rank || '1'}
          </div>
        </div>
      `).join('');

      container.innerHTML = cardsHtml;
      container.classList.remove('opacity-0');
      container.classList.add('work-loaded');
    } catch (error) {
      console.error('Failed to fetch works:', error);
      if (container) {
        container.innerHTML = '<div class="text-white/80 p-12">Unable to load featured works at this time.</div>';
        container.classList.remove('opacity-0');
      }
    }
  };

  let previousWorksLoaded = false;
  const startPreviousWorks = () => {
    if (previousWorksLoaded) return;
    previousWorksLoaded = true;
    fetchAndInit();
  };

  document.addEventListener('astro:page-load', startPreviousWorks);
  document.addEventListener('DOMContentLoaded', startPreviousWorks);
  window.addEventListener('load', startPreviousWorks);
  if (document.readyState === 'complete' || document.readyState === 'interactive') startPreviousWorks();
</script>