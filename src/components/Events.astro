---
// EventsGallery.astro
// Removed server-side fetch to ensure compatibility with static 'dist' deployment.
---

<div class="py-20 px-6 md:px-12 lg:px-24 bg-[#042425]">
  <section class="max-w-[1400px] mx-auto">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
      <div class="max-w-xl">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tighter text-[#F8FAF9] font-main">Upcoming Events</h2>
        <p class="mt-4 text-[#F8FAF9]/60 text-lg italic font-body">Cinematic moments, curated for the bold.</p>
      </div>
      
      <div class="flex gap-3 self-end">
        <button id="prev-btn" class="nav-arrow group opacity-30" aria-label="Previous">
          <svg class="w-6 h-6 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="next-btn" class="nav-arrow group opacity-30" aria-label="Next">
          <svg class="w-6 h-6 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>

    <div id="events-container" class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory no-scrollbar pb-10 opacity-0 transition-opacity duration-700">
      </div>
  </section>
</div>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  .nav-arrow {
    width: 3.5rem;
    height: 3.5rem;
    display: grid;
    place-items: center;
    border-radius: 99px;
    border: 1px solid rgba(248, 250, 249, 0.2);
    color: #F8FAF9;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-arrow:hover {
    background: #F8FAF9;
    color: #042425;
    border-color: #F8FAF9;
  }

  /* Ensure hover effects work on injected content */
  @media (max-width: 768px) {
    :global(.event-card .mobile-visible) {
      max-height: 10rem !important;
      opacity: 1 !important;
    }
  }
</style>

<script>
  const PAYLOAD_URL = "https://cms.darievents.com"; // Update to production URL later

  const formatDate = (dateString: string) => {
    return new Date(dateString).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    });
  };

  const fetchEvents = async () => {
    const container = document.getElementById('events-container');
    if (!container) return;

    const now = new Date().toISOString();

    try {
      const response = await fetch(
        `${PAYLOAD_URL}/api/events?where[date][greater_than_equal]=${now}&sort=date&depth=2`
      );
      const data = await response.json();
      const events = (data.docs || []).slice(0, 5);

      if (events.length === 0) {
        container.innerHTML = `<p class="text-white/40 italic">No upcoming events scheduled.</p>`;
        container.classList.remove('opacity-0');
        return;
      }

      const eventsHtml = events.map((event: any) => `
        <a href="/events/${event.id}" class="event-card group relative flex-shrink-0 w-[85vw] md:w-[45vw] lg:w-[35vw] aspect-[3/4] rounded-[2rem] overflow-hidden snap-start cursor-pointer block">
          <img 
            src="${PAYLOAD_URL}${event.poster.url}" 
            alt="${event.poster.alt || event.title}" 
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-1000 ease-out group-hover:scale-110" 
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#042425] via-transparent to-black/20"></div>
          <div class="absolute inset-0 p-8 md:p-10 flex flex-col justify-end overflow-hidden">
            <div class="mb-2">
              <span class="text-[#f5bd02] text-xs font-bold uppercase tracking-[0.2em] font-body">${formatDate(event.date)}</span>
              <h3 class="text-[#F8FAF9] text-3xl md:text-4xl font-bold leading-none mt-2 font-main">${event.title}</h3>
            </div>
            <div class="mobile-visible max-h-0 opacity-0 group-hover:max-h-40 group-hover:opacity-100 transition-all duration-500 ease-in-out">
              <p class="text-[#F8FAF9]/80 mt-4 text-sm md:text-base line-clamp-2 font-body">
                ${event.location}
              </p>
              <div class="mt-6 flex items-center justify-between">
                <div class="flex flex-wrap gap-2">
                  ${(event.featuredArtists || []).map((artist: any) => `
                    <span class="text-[10px] px-2 py-1 border border-[#F8FAF9]/20 rounded-full text-[#F8FAF9]/60 font-body">
                      ${artist.name}
                    </span>
                  `).join('')}
                </div>
                <div class="flex items-center gap-2 text-[#f5bd02] font-semibold text-sm font-body">
                  View Event <span class="text-xl">→</span>
                </div>
              </div>
            </div>
          </div>
        </a>
      `).join('');

      container.innerHTML = eventsHtml;
      container.classList.remove('opacity-0');
      
      // Re-init the navigation logic now that content exists
      initNav();

    } catch (err) {
      console.error("Event fetch error:", err);
    }
  };

  const initNav = () => {
    const container = document.getElementById('events-container');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');

    if (container && prevBtn && nextBtn) {
      // Enable buttons
      prevBtn.classList.remove('opacity-30');
      nextBtn.classList.remove('opacity-30');

      nextBtn.addEventListener('click', () => container.scrollBy({ left: 400, behavior: 'smooth' }));
      prevBtn.addEventListener('click', () => container.scrollBy({ left: -400, behavior: 'smooth' }));

      container.addEventListener('scroll', () => {
        const isAtEnd = container.scrollLeft + container.clientWidth >= container.scrollWidth - 10;
        const isAtStart = container.scrollLeft <= 10;
        (prevBtn as HTMLElement).style.opacity = isAtStart ? "0.3" : "1";
        (nextBtn as HTMLElement).style.opacity = isAtEnd ? "0.3" : "1";
      });
    }
  };

  document.addEventListener('astro:page-load', fetchEvents);
  if (document.readyState === 'complete') fetchEvents();
</script>