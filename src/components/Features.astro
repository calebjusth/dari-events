---
const companies = [
  { name: "sinqee", logo: "/sample/sinqee.png" },
  { name: "Ethio telecome", logo: "/sample/ethio.png" },
  { name: "telebir", logo: "/sample/telebirr.png" },
  { name: "arada", logo: "/sample/arada.png" },
];
---

<section class="bg-primary-green py-32 px-4">
  <div class="mx-auto max-w-7xl text-center mb-20">
    <h2 class="reveal text-4xl md:text-6xl font-bold text-off-white leading-tight">
      Sponsers & <br />
      Collabs
    </h2>
  </div>

  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      {companies.map((company) => (
        <div class="reveal group flex items-center justify-center p-8 bg-off-white/10 backdrop-blur-sm rounded-2xl hover:bg-off-white/20 transition-all duration-300 hover:scale-105">
          <img
            src={company.logo}
            alt={`${company.name} logo`}
            class="max-w-full max-h-16 md:max-h-20 object-contain filter brightness-0 invert opacity-70 group-hover:opacity-100 transition-opacity duration-300"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Simple Intersection Observer to trigger the "reveal" classes
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>