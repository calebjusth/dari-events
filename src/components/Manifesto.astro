---
// Dari Manifesto - Curtain Reveal Edition
const message = "DARI EVENTS is an experience-first agency reshaping how audiences connect with culture in Ethiopia. Rooted in polite disruption, We craft cinematic moments that leave a lasting emotional impact.";
const words = message.split(" ");
---

<section id="manifesto" class="manifesto-section relative w-full py-32 md:py-48 px-6 md:px-12 lg:px-24 bg-[#042425] overflow-hidden">
  <div class="max-w-[1500px] mx-auto text-left">
    <h2 class="manifesto-grid text-[clamp(1.5rem,3vw,4.5rem)] leading-[1.05] font-bold capitalize tracking-tighter text-[#F8FAF9] flex flex-wrap items-baseline">
      {words.map((word, index) => (
        <span class="word-wrapper relative inline-block overflow-hidden mr-[0.3em] py-[0.1em]">
          <span class="word inline-block translate-y-[110%]">{word}</span>
          
          {index === 4 && (
            <span class="inline-jewel relative inline-block align-middle overflow-hidden bg-white/10 opacity-0 scale-0">
              <img src="/inline_image2.jpg" alt="Culture" class="absolute inset-0 w-full h-full object-cover" />
            </span>
          )}
          
          {index === 11 && (
            <span class="inline-jewel relative inline-block align-middle overflow-hidden bg-white/10 opacity-0 scale-0">
               <img src="/inline_image1.jpg" alt="Moment" class="absolute inset-0 w-full h-full object-cover" />
            </span>
          )}

          {index === 20 && (
            <span class="inline-icon relative inline-flex items-center justify-center bg-[#f5bd02] rounded-full align-middle opacity-0 scale-0">
               <svg class="w-1/2 h-1/2 text-black" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
            </span>
          )}
        </span>
      ))}
    </h2>

    <div class="mt-20">
      <a href="/aboutus" class="discover-link inline-flex items-center gap-2 text-xl font-medium text-[#F8FAF9] hover:gap-6 transition-all duration-500 border-b border-white/30 pb-2">
        Build your experience <span class="text-3xl">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .manifesto-grid {
    font-family: var(--font-main);
  }

  /* Responsive Jewel Sizing based on increased font size */
  .inline-jewel {
    width: 2.4em; 
    height: 1.5em;
    border-radius: 4rem;
    margin-left: 0.15em;
    transform-origin: center;
  }

  .inline-icon {
    width: 1.4em;
    height: 1.4em;
    margin-left: 0.15em;
    transform-origin: center;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const animateManifesto = () => {
    const section = document.querySelector('#manifesto');
    if (!section) return;

    const words = section.querySelectorAll('.word');
    const jewels = section.querySelectorAll('.inline-jewel, .inline-icon');

    let ctx = gsap.context(() => {
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 75%',
          // If you want it to trigger once on load/scroll without scrubbing, 
          // you can remove 'scrub' and use toggleActions.
          toggleActions: 'play none none reverse' 
        }
      });

      // The "Curtain" Reveal
      tl.to(words, {
        y: '0%',
        duration: 1.2,
        ease: 'power4.out',
        stagger: 0.03
      });

      // Pop the images in slightly after the words start moving
      tl.to(jewels, {
        scale: 1,
        opacity: 1,
        duration: 0.8,
        ease: 'back.out(1.7)',
        stagger: 0.1
      }, "-=0.8");

    }, section);
  };

  document.addEventListener('astro:page-load', animateManifesto);
</script>