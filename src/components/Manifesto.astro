---
// Dari Manifesto - Curtain Reveal Edition
const message = "Dari Events is an experience-first agency reshaping how audiences connect with URBAN culture in Ethiopia. Rooted in polite disruption, We craft cinematic moments that leave a lasting emotional impact.";
const words = message.split(" ");
---

<section id="manifesto" class="manifesto-section relative w-full py-32 md:py-48 px-6 md:px-12 lg:px-24 bg-[#042425] overflow-hidden">
  <div class="max-w-[1500px] mx-auto text-left">
    <h2 class="manifesto-grid text-[clamp(2rem,4vw,5.5rem)] leading-[1.05] font-bold capitalize tracking-tighter text-[#F8FAF9] flex flex-wrap items-baseline">
      {words.map((word, index) => (
        <span class="word-wrapper relative inline-block overflow-hidden mr-[0.3em] py-[0.1em]">
          <span class="word inline-block translate-y-[110%]">{word}</span>
          
          {/* Index 4: experience-first */}
          {index === 4 && (
            <span class="inline-jewel relative inline-block align-middle overflow-hidden bg-white/10 opacity-0 scale-0">
              <img src="/hero-main.jpg" alt="Culture" class="absolute inset-0 w-full h-full object-cover" />
            </span>
          )}

          
          
          {/* Index 11: culture */}
          {index === 11 && (
            <span class="inline-jewel relative inline-block align-middle overflow-hidden bg-white/10 opacity-0 scale-0">
               <img src="/DSC05738.jpg" alt="Moment" class="absolute inset-0 w-full h-full object-cover" />
            </span>
          )}

          {/* NEW Index 15: polite */}
          {index === 15 && (
            <span class="inline-jewel relative inline-block align-middle overflow-hidden bg-white/10 opacity-0 scale-0">
              <img src="/hero-main.jpg" alt="Impact" class="absolute inset-0 w-full h-full object-cover" />
            </span>
          )}

          {/* Index 20: cinematic */}
          {index === 20 && (
            <span class="inline-icon relative inline-flex items-center justify-center bg-[#f5bd02] rounded-full align-middle opacity-0 scale-0">
                <img src="/hero-main.jpg" alt="Culture" class="absolute inset-0 w-full h-full object-cover" />               
            </span>
          )}
        </span>
      ))}
    </h2>

    <div class="mt-20">
      <a href="/aboutus" class="discover-link inline-flex items-center gap-2 text-xl font-medium text-[#F8FAF9] hover:gap-6 transition-all duration-500 border-b border-white/30 pb-2">
        Build your experience <span class="text-3xl">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .manifesto-grid {
    font-family: var(--font-main);
  }

  /* Adjusted jewel sizing for larger text */
  .inline-jewel {
    width: 2.2em; 
    height: 1.3em;
    border-radius: 4rem;
    margin-left: 0.15em;
    transform-origin: center;
  }

  .inline-icon {
    width: 1.2em;
    height: 1.2em;
    margin-left: 0.15em;
    transform-origin: center;
  }
</style>

<script type="module">
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  let manifestoAnimated = false;

  const animateManifesto = () => {
    if (manifestoAnimated) return;
    const section = document.querySelector('#manifesto');
    if (!section) return;

    manifestoAnimated = true;
    const words = section.querySelectorAll('.word');
    const jewels = section.querySelectorAll('.inline-jewel, .inline-icon');

    let ctx = gsap.context(() => {
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 75%',
          toggleActions: 'play none none reverse'
        }
      });

      tl.to(words, {
        y: '0%',
        duration: 1.1,
        ease: 'power4.out',
        stagger: 0.02
      });

      tl.to(jewels, {
        scale: 1,
        opacity: 1,
        duration: 0.9,
        ease: 'back.out(1.5)',
        stagger: 0.08
      }, '<');

    }, section);
  };

  document.addEventListener('astro:page-load', animateManifesto);
  document.addEventListener('DOMContentLoaded', animateManifesto);
  window.addEventListener('load', animateManifesto);
  if (document.readyState === 'complete') animateManifesto();
</script>