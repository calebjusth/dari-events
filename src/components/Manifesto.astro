---
// Dari Manifesto - Curtain Reveal Edition
const message = "Dari Events is an experience-first agency reshaping how audiences connect with URBAN culture in Ethiopia. Rooted in polite disruption, We craft cinematic moments that leave a lasting emotional impact.";
const words = message.split(" ");
---

<section id="manifesto" class="manifesto-section relative w-full py-32 md:py-48 px-6 md:px-12 lg:px-24 bg-[#042425] overflow-hidden">
  <div class="max-w-[1500px] mx-auto text-left">
    <h2 class="manifesto-grid text-[clamp(2rem,4vw,5.5rem)] leading-[1.05] font-bold capitalize tracking-tighter text-[#F8FAF9] flex flex-wrap items-baseline">
      {words.map((word, index) => (
        <span class="word-wrapper relative inline-block overflow-hidden mr-[0.3em] py-[0.1em]">
          <span class="word">
            {word}
          </span>
          
          {/* Index 4: experience-first */}
          {index === 4 && (
            <span class="inline-jewel relative inline-block align-middle overflow-hidden bg-white/10">
              <img src="/hero-main.jpg" alt="Culture" class="absolute inset-0 w-full h-full object-cover" />
            </span>
          )}

          
          
          {/* Index 11: culture */}
          {index === 11 && (
            <span class="inline-jewel relative inline-block align-middle overflow-hidden bg-white/10">
               <img src="/DSC05738.jpg" alt="Moment" class="absolute inset-0 w-full h-full object-cover" />
            </span>
          )}

          {/* NEW Index 15: polite */}
          {index === 15 && (
            <span class="inline-jewel relative inline-block align-middle overflow-hidden bg-white/10">
              <img src="/hero-main.jpg" alt="Impact" class="absolute inset-0 w-full h-full object-cover" />
            </span>
          )}

          {/* Index 20: cinematic */}
          {index === 20 && (
            <span class="inline-icon relative inline-flex items-center justify-center bg-[#f5bd02] rounded-full align-middle">
                <img src="/hero-main.jpg" alt="Culture" class="absolute inset-0 w-full h-full object-cover" />               
            </span>
          )}
        </span>
      ))}
    </h2>

    <div class="mt-20">
      <a href="/aboutus" class="discover-link inline-flex items-center gap-2 text-xl font-medium text-[#F8FAF9] hover:gap-6 transition-all duration-500 border-b border-white/30 pb-2">
        Build your experience <span class="text-3xl">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .manifesto-grid {
    font-family: var(--font-main);
  }

  .word,
  .inline-jewel,
  .inline-icon {
    opacity: 0;
    transform: translateY(24px) scale(0.95);
    transition: transform 0.8s ease, opacity 0.8s ease;
    transition-delay: var(--delay, 0s);
    display: inline-block;
  }

  .manifesto-animate .word,
  .manifesto-animate .inline-jewel,
  .manifesto-animate .inline-icon {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .inline-jewel {
    width: 2.2em;
    height: 1.3em;
    border-radius: 4rem;
    margin-left: 0.15em;
    transform-origin: center;
    position: relative;
    overflow: hidden;
  }

  .inline-icon {
    width: 1.2em;
    height: 1.2em;
    margin-left: 0.15em;
    transform-origin: center;
    position: relative;
    overflow: hidden;
  }
</style>

<script>
  const initManifesto = () => {
    const section = document.querySelector('#manifesto');
    if (!section || section.classList.contains('manifesto-animate')) return;

    const elements = section.querySelectorAll('.word, .inline-jewel, .inline-icon');
    elements.forEach((el, index) => {
      el.style.setProperty('--delay', `${index * 0.025}s`);
    });

    section.classList.add('manifesto-animate');
  };

  const observeManifesto = () => {
    const section = document.querySelector('#manifesto');
    if (!section) return;

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            initManifesto();
            observer.disconnect();
          }
        });
      }, { threshold: 0.2 });

      observer.observe(section);
    } else {
      initManifesto();
    }
  };

  document.addEventListener('astro:page-load', observeManifesto);
  document.addEventListener('DOMContentLoaded', observeManifesto);
  window.addEventListener('load', observeManifesto);
  if (document.readyState === 'complete' || document.readyState === 'interactive') observeManifesto();
</script>